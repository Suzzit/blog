<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="shortcut icon" href="/images/myself.png" type="image/x-icon">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&family=JetBrains+Mono:wght@400&display=swap"
        rel="stylesheet">

    <title>The Single Source of Truth in Parallel Systems — suzzit.dev</title>

    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/hero.css">
    <link rel="stylesheet" href="/styles/navbar.css">
    <link rel="stylesheet" href="/styles/footer.css">

    <style>
        /* ── Blog-specific styles only ── */
        :root {
            --navy: #0C447C;
            --sky: #B5D4F4;
            --ice: #E6F1FB;
            --dark: #1A1A1A;
            --mid: #4A4A4A;
            --muted: #8A8A8A;
            --rule: #E0E0DC;
            --pull-bg: #EEF5FC;
            --good-bg: #EAF5F0;
            --good: #1D9E75;
            --warn-bg: #FEF9EC;
            --warn: #BA7517;
            --danger-bg: #FEF0EE;
            --danger: #A32D2D;
            --close-bg: #F5F5F3;
            --coral: #D85A30;
        }

        body {
            font-family: 'Source Serif 4', Georgia, serif;
            font-weight: 300;
            color: var(--dark);
            background: #fafaf8;
        }

        /* Article layout */
        .blog-article {
            max-width: 740px;
            margin: 0 auto;
            padding: 6rem 1.5rem 4rem;
        }

        /* Kicker */
        .blog-kicker {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--navy);
            margin-bottom: 1rem;
        }

        .blog-kicker span {
            opacity: 0.45;
            margin: 0 6px;
        }

        /* Headline */
        .blog-headline {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 5vw, 2.9rem);
            font-weight: 600;
            line-height: 1.15;
            color: var(--dark);
            margin-bottom: 1.1rem;
            letter-spacing: -0.01em;
        }

        /* Subhead */
        .blog-subhead {
            font-size: 1.15rem;
            font-weight: 300;
            font-style: italic;
            color: var(--mid);
            line-height: 1.65;
            border-left: 3px solid var(--navy);
            padding-left: 1rem;
            margin-bottom: 1.5rem;
        }

        /* Meta */
        .blog-meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--muted);
            display: flex;
            flex-wrap: wrap;
            gap: 1.2rem;
            padding: 1rem 0;
            border-top: 1px solid var(--rule);
            border-bottom: 1px solid var(--rule);
            margin-bottom: 2.5rem;
        }

        /* Body copy */
        .blog-body p {
            font-size: 1.08rem;
            line-height: 1.85;
            color: var(--dark);
            margin-bottom: 1.25rem;
        }

        .blog-body strong {
            font-weight: 600;
        }

        /* Section accent */
        .section-accent {
            width: 36px;
            height: 3px;
            background: var(--navy);
            border-radius: 2px;
            margin: 2rem 0;
        }

        /* H2 */
        .blog-body h2 {
            font-family: 'Playfair Display', serif;
            font-size: 1.55rem;
            font-weight: 600;
            color: var(--dark);
            margin: 2.5rem 0 0.75rem;
            line-height: 1.3;
        }

        /* H3 */
        .blog-body h3 {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            letter-spacing: 0.09em;
            text-transform: uppercase;
            color: var(--navy);
            margin: 2rem 0 0.6rem;
        }

        /* Pull quote */
        .pull-quote {
            background: var(--pull-bg);
            border-left: 4px solid var(--navy);
            border-radius: 0 8px 8px 0;
            padding: 1.4rem 1.6rem;
            margin: 2rem 0;
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 1.15rem;
            color: var(--navy);
            line-height: 1.7;
        }

        /* Diagram boxes */
        .diagram-wrap {
            background: #f4f4f2;
            border: 1px solid var(--rule);
            border-radius: 10px;
            padding: 1.4rem;
            margin: 1.5rem 0;
        }

        .diagram-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 1rem;
        }

        /* Split-brain problem diagram */
        .prob-nodes {
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .prob-node {
            flex: 1;
            min-width: 120px;
            text-align: center;
            border-radius: 8px;
            padding: 0.9rem 0.75rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            line-height: 1.6;
        }

        .prob-node.normal {
            background: var(--ice);
            border: 1px solid var(--sky);
            color: var(--navy);
        }

        .prob-node.conflict {
            background: var(--danger-bg);
            border: 2px solid var(--coral);
            color: var(--coral);
        }

        .prob-node strong {
            display: block;
            font-size: 1rem;
            margin-top: 2px;
        }

        .prob-caption {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: var(--muted);
            text-align: center;
            margin-top: 0.75rem;
            font-style: italic;
        }

        /* SSOT architecture diagram */
        .ssot-arch {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0;
        }

        .ssot-source-node {
            background: var(--ice);
            border: 2px solid var(--navy);
            border-radius: 8px;
            padding: 0.75rem 2.2rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--navy);
            font-weight: 600;
            letter-spacing: 0.04em;
        }

        .ssot-arrow {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 2px 0;
        }

        .ssot-arrow-line {
            width: 2px;
            height: 24px;
            background: #b0b0b0;
        }

        .ssot-arrow-head {
            width: 0;
            height: 0;
            border-left: 6px solid transparent;
            border-right: 6px solid transparent;
            border-top: 8px solid #b0b0b0;
        }

        .ssot-consumers {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .ssot-consumer {
            background: white;
            border: 1px solid var(--rule);
            border-radius: 7px;
            padding: 0.6rem 0.85rem;
            text-align: center;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            color: var(--mid);
            min-width: 100px;
        }

        .ssot-consumer em {
            display: block;
            font-style: normal;
            font-size: 0.65rem;
            color: var(--muted);
            margin-top: 2px;
        }

        /* Pattern grid */
        .pattern-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 12px;
            margin: 1.25rem 0;
        }

        .pattern-card {
            background: white;
            border: 1px solid var(--rule);
            border-top: 3px solid var(--navy);
            border-radius: 8px;
            padding: 1rem 1.1rem;
        }

        .pattern-card .p-name {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 0.4rem;
        }

        .pattern-card .p-desc {
            font-family: 'Source Serif 4', serif;
            font-size: 0.88rem;
            color: var(--mid);
            line-height: 1.55;
            font-weight: 300;
        }

        /* Consistency table */
        .cons-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.88rem;
            margin: 1rem 0;
        }

        .cons-table th {
            background: #f0f0ee;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0.6rem 0.9rem;
            text-align: left;
            border-bottom: 1px solid var(--rule);
        }

        .cons-table td {
            padding: 0.7rem 0.9rem;
            border-bottom: 1px solid var(--rule);
            vertical-align: middle;
            color: var(--dark);
            font-family: 'Source Serif 4', serif;
            font-weight: 300;
        }

        .cons-table tr:last-child td {
            border-bottom: none;
        }

        .badge-lat {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 999px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.68rem;
            font-weight: 600;
            white-space: nowrap;
        }

        .badge-high {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .badge-medium {
            background: var(--warn-bg);
            color: var(--warn);
        }

        .badge-low {
            background: var(--good-bg);
            color: var(--good);
        }

        /* Checklist */
        .checklist-box {
            background: #f8f8f7;
            border: 1px solid var(--rule);
            border-radius: 10px;
            overflow: hidden;
            margin: 1.25rem 0;
        }

        .checklist-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 0.85rem 1.1rem;
            border-bottom: 1px solid var(--rule);
            font-family: 'Source Serif 4', serif;
            font-size: 0.98rem;
            color: var(--dark);
            font-weight: 300;
            line-height: 1.6;
        }

        .checklist-item:last-child {
            border-bottom: none;
        }

        .check-icon {
            flex-shrink: 0;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--good-bg);
            border: 1.5px solid var(--good);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 2px;
        }

        .check-icon svg {
            width: 11px;
            height: 11px;
            stroke: var(--good);
            stroke-width: 2.5;
            fill: none;
        }

        /* Closing box */
        .closing-box {
            background: var(--close-bg);
            border: 1px solid var(--rule);
            border-top: 3px solid var(--navy);
            border-radius: 10px;
            padding: 1.6rem 1.75rem;
            margin-top: 2.5rem;
        }

        .closing-box h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 0.6rem;
            color: var(--dark);
        }

        .closing-box p {
            font-size: 1rem;
            color: var(--mid);
            line-height: 1.75;
            margin: 0;
        }

        /* Footer override for blog page spacing */
        footer {
            margin-top: 4rem;
        }

        @media (max-width: 576px) {
            .blog-article {
                padding: 5rem 1rem 3rem;
            }

            .blog-headline {
                font-size: 1.75rem;
            }

            .pattern-grid {
                grid-template-columns: 1fr;
            }

            .ssot-consumers {
                gap: 6px;
            }

            .cons-table {
                font-size: 0.8rem;
            }

            .cons-table th,
            .cons-table td {
                padding: 0.5rem 0.6rem;
            }
        }
    </style>
</head>

<body>

